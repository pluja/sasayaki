# Required: your languages (space-separated, any language name the LLM understands)
LANGUAGES=English Spanish German

# Required: LLM API for data generation and review
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=claude-sonnet-4-6

# Data generation
NUM_EXAMPLES=1000
# LANGUAGE_WEIGHTS=English:3,German:2,Spanish:1
# CONTEXT_WEIGHTS=chat:3,email:1,notes:1,social:1

# Training
BASE_MODEL=unsloth/Qwen3.5-2B
GGUF_QUANTIZATION=q4_k_m q8_0
